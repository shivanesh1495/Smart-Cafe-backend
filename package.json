{
  "name": "smart-cafe-backend",
  "version": "1.0.0",
  "description": "Backend API for Smart Cafe application",
  "main": "src/server.js",
  "scripts": {
    "start": "concurrently \"node src/server.js\" \"cd forecasting_api && set PYTHONIOENCODING=utf8 && python api.py\"",
    "dev": "concurrently \"nodemon src/server.js\" \"cd forecasting_api && set PYTHONIOENCODING=utf8 && python api.py\"",
    "start:node": "node src/server.js",
    "dev:node": "nodemon src/server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --detectOpenHandles --forceExit",
    "seed": "node src/scripts/seed.js",
    "seed:slots": "node seed_system_slots.js",
    "seed:daily": "node seed_system_slots.js --daily"
  },
  "keywords": [
    "express",
    "mongodb",
    "jwt",
    "cafe",
    "booking"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.12.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.6",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  }
}
